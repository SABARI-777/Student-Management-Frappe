 "font_size": 14,
 "html": "<style>\n    .report-title {\n        text-align: center;\n        font-size: 22px;\n        font-weight: bold;\n        margin-bottom: 15px;\n    }\n\n    table {\n        width: 100%;\n        border-collapse: collapse;\n        font-family: Arial, sans-serif;\n        font-size: 13px;\n    }\n\n    th, td {\n        border: 1px solid #000;\n        padding: 8px;\n    }\n\n    th {\n        background-color: #e6e6e6;\n        text-align: left;\n    }\n\n    .section {\n        background-color: #d9edf7;\n        text-align: center;\n        font-size: 15px;\n        font-weight: bold;\n    }\n</style>\n\n<div class=\"report-title\">\n    STUDENT REPORT\n</div>\n\n<table>\n\n    <tr>\n        <th colspan=\"4\" class=\"section\">Student Information</th>\n    </tr>\n\n    <tr>\n        <th>Name</th>\n        <td>{{ doc.name1 }}</td>\n\n        <th>Department</th>\n        <td>{{ doc.dept }}</td>\n    </tr>\n\n    <tr>\n        <th>Year</th>\n        <td>{{ doc.year }}</td>\n\n        <th>Age</th>\n        <td>{{ doc.age }}</td>\n    </tr>\n\n    <tr>\n        <th>Phone</th>\n        <td>{{ doc.phone }}</td>\n\n        <th>Email</th>\n        <td>{{ doc.email }}</td>\n    </tr>\n\n    <tr>\n        <th>Registration No.</th>\n        <td>{{ doc.name }}</td>\n\n        <th>Date</th>\n        <td>{{ frappe.format(doc.date, {\"fieldtype\":\"Date\"}) }}</td>\n    </tr>\n\n    <tr>\n        <th>Document</th>\n        <td colspan=\"3\">{{ doc.document }}</td>\n    </tr>\n\n    {% if doc.amended_from %}\n    <tr>\n        <th>Amended From</th>\n        <td colspan=\"3\">{{ doc.amended_from }}</td>\n    </tr>\n    {% endif %}\n\n    <tr>\n        <th colspan=\"4\" class=\"section\">Marks Details</th>\n    </tr>\n\n    <tr>\n        <th>Mark 1</th>\n        <th>Mark 2</th>\n        <th>Total</th>\n        <th>Result</th>\n    </tr>\n\n    <tr>\n        <td align=\"center\">{{ doc.mark1 }}</td>\n        <td align=\"center\">{{ doc.mark2 }}</td>\n        <td align=\"center\"><b>{{ doc.total }}</b></td>\n        <td align=\"center\">\n            {% if doc.total >= 50 %}\n                PASS\n            {% else %}\n                FAIL\n            {% endif %}\n        </td>\n    </tr>\n\n</table>\n\n<br><br>\n\n<table>\n    <tr>\n        <td style=\"border:none;text-align:left;\">\n            Student Signature\n            <br><br><br>\n            ____________________\n        </td>\n\n        <td style=\"border:none;text-align:right;\">\n            Authorized Signature\n            <br><br><br>\n            ____________________\n        </td>\n    </tr>\n</table>",
